livedebugging {
	enabled = true
}

// Receive frontend telemetry from the Faro Web SDK
faro.receiver "default" {
	server {
		listen_address = "0.0.0.0"
		listen_port    = 12347

		cors_allowed_origins = ["*"]
	}

	output {
		logs = [loki.write.local.receiver]
	}
}

loki.write "local" {
	endpoint {
		url = "http://loki:3100/loki/api/v1/push"
	}
}
